{
  "workflow_id": "HW1 - Lead Capture Pipeline",
  "config": {
    "node-1-trigger": {
      "method": "POST",
      "path": "/api/webhook/lead-capture",
      "authentication": "none",
      "expected_payload": {
        "name": "string",
        "email": "string",
        "message": "string"
      }
    },
    "node-2-processing": {
      "mapping_rules": {
        "leadName": "{{ incoming.body.name }}",
        "leadEmail": "{{ incoming.body.email }}",
        "leadMessage": "{{ incoming.body.message }}",
        "receivedAt": "{{ $timestamp }}"
      }
    },
    "node-3-validation": {
      "input": {
        "name": "{{ node-2-processing.leadName }}",
        "email": "{{ node-2-processing.leadEmail }}",
        "message": "{{ node-2-processing.leadMessage }}"
      }
    },
    "node-4-ai": {
      "provider": "google-gemini",
      "model": "gemini-2.5-flash-lite",
      "api_key": "{{ $env.GEMINI_API_KEY }}",
      "prompt": "You are an AI assistant. Analyze the following incoming lead message. Output a raw JSON object with no markdown formatting containing EXACTLY two keys: 'Intent' (e.g., Support, Sales, Partnership) and 'Urgency' (e.g., High, Medium, Low).\n\nMessage: {{ node-2-processing.leadMessage }}",
      "parseJSON": true
    },
    "node-5-google-sheets": {
      "spreadsheet_id": "{{ $env.GOOGLE_SHEETS_ID }}",
      "credentials_path": "{{ $env.GOOGLE_SERVICE_ACCOUNT_PATH }}",
      "action": "appendRow",
      "range": "Leads!A:G",
      "data": {
        "Name": "{{ node-2-processing.leadName }}",
        "Email": "{{ node-2-processing.leadEmail }}",
        "Message": "{{ node-2-processing.leadMessage }}",
        "Date": "{{ node-2-processing.receivedAt }}",
        "ValidationStatus": "{{ node-3-validation.status }}",
        "Intent": "{{ node-4-ai.Intent }}",
        "Urgency": "{{ node-4-ai.Urgency }}"
      }
    }
  }
}
